{
  "name": "Ember Preset",
  "desc": "Warm restaurant-style preset with terracotta amber highlights and charcoal depth",
  "version": "1.0.0",
  "themeScheme": "dark",
  "grayscale": false,
  "colourWeakness": false,
  "recommendColor": false,
  "themeColor": "#de7a34",
  "otherColor": {
    "info": "#4da3b5",
    "success": "#4ca97d",
    "warning": "#e4a43d",
    "error": "#dd5f52"
  },
  "themeRadius": 14,
  "isInfoFollowPrimary": true,
  "layout": {
    "mode": "vertical",
    "scrollMode": "content"
  },
  "page": {
    "animate": true,
    "animateMode": "fade-slide"
  },
  "header": {
    "height": 56,
    "breadcrumb": {
      "visible": true,
      "showIcon": true
    },
    "multilingual": {
      "visible": false
    },
    "globalSearch": {
      "visible": true
    }
  },
  "tab": {
    "visible": true,
    "cache": true,
    "height": 44,
    "mode": "chrome",
    "closeTabByMiddleClick": false
  },
  "fixedHeaderAndTab": true,
  "sider": {
    "inverted": false,
    "width": 220,
    "collapsedWidth": 64,
    "mixWidth": 90,
    "mixCollapsedWidth": 64,
    "mixChildMenuWidth": 200
  },
  "footer": {
    "visible": true,
    "fixed": false,
    "height": 48,
    "right": true
  },
  "watermark": {
    "visible": false,
    "text": "Henfon",
    "enableUserName": false,
    "enableTime": false,
    "timeFormat": "YYYY-MM-DD HH:mm"
  },
  "tokens": {
    "light": {
      "colors": {
        "container": "rgb(255, 250, 246)",
        "layout": "rgb(245, 236, 230)",
        "inverted": "rgb(43, 30, 24)",
        "base-text": "rgb(58, 40, 32)"
      },
      "boxShadow": {
        "header": "0 12px 30px rgb(113, 69, 42, 0.08)",
        "sider": "12px 0 28px 0 rgb(113, 69, 42, 0.06)",
        "tab": "0 10px 24px rgb(113, 69, 42, 0.06)"
      }
    },
    "dark": {
      "colors": {
        "container": "rgb(29, 22, 19)",
        "layout": "rgb(20, 16, 14)",
        "base-text": "rgb(239, 228, 219)"
      }
    }
  },
  "naiveui": {
    "Alert": {
      "borderRadiusMedium": "14px",
      "fontWeightStrong": "600",
      "paddingMedium": "0 20px"
    },
    "Button": {
      "borderRadiusMedium": "12px",
      "fontWeightStrong": "600"
    },
    "Card": {
      "borderRadius": "18px",
      "paddingMedium": "24px"
    },
    "Input": {
      "borderRadius": "12px"
    }
  }
}
