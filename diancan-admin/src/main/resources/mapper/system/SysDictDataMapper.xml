<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.scaffold.modules.system.mapper.SysDictDataMapper">

    <resultMap id="BaseResultMap" type="com.scaffold.modules.system.entity.SysDictData">
        <id column="id" property="id"/>
        <result column="type_id" property="typeId"/>
        <result column="label" property="label"/>
        <result column="value" property="value"/>
        <result column="order_num" property="orderNum"/>
        <result column="status" property="status"/>
        <result column="remark" property="remark"/>
        <result column="create_by" property="createBy"/>
        <result column="update_by" property="updateBy"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <!-- 根据字典类型ID删除数据 -->
    <delete id="deleteByTypeId">
        DELETE FROM sys_dict_data WHERE type_id = #{typeId}
    </delete>

</mapper>
