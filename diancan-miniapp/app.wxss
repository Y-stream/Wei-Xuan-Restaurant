/* ========== 全局样式变量 ========== */
page {
  --primary: #5f7f52;
  --primary-light: #edf4e7;
  --primary-dark: #314a2d;
  --bg: #f4f1e9;
  --card: #fbfcf8;
  --text-primary: #22301f;
  --text-secondary: #788373;
  --text-muted: #93a08f;
  --price: #628056;
  --border: #dce6d4;
  --success: #4f8a5b;
  --warning: #9b7b46;

  background: var(--bg);
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
}

/* ========== 容器 ========== */
.container {
  box-sizing: border-box;
}

/* ========== 安全区底部 ========== */
.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* ========== 按钮基础 ========== */
button {
  margin: 0;
  padding: 0;
  line-height: inherit;
  font-size: inherit;
}
button::after {
  border: none;
}

.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 24rpx;
  border: 1rpx solid rgba(7, 193, 96, 0.28);
  box-shadow: 0 12rpx 26rpx rgba(7, 193, 96, 0.18);
}
.btn-primary:active {
  background: linear-gradient(135deg, #06b85a 0%, #059b4d 100%);
}
.btn-primary[disabled] {
  background: #e6dad4;
  color: #887872;
  border-color: rgba(136, 120, 114, 0.28);
  box-shadow: none;
}

.btn-outline {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 72rpx;
  background: rgba(255, 253, 251, 0.96);
  color: #07c160;
  font-size: 28rpx;
  font-weight: 700;
  border-radius: 24rpx;
  border: 1rpx solid rgba(7, 193, 96, 0.16);
  box-shadow: 0 8rpx 18rpx rgba(5, 122, 61, 0.04);
}

.btn-sm {
  height: 56rpx;
  font-size: 24rpx;
  border-radius: 20rpx;
  padding: 0 24rpx;
}

/* ========== 文字 ========== */
.price-text {
  color: var(--price);
  font-weight: 700;
  font-size: 32rpx;
}
.price-text::before {
  content: '¥';
  font-size: 24rpx;
}

.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.text-secondary {
  color: var(--text-secondary);
  font-size: 24rpx;
}

/* ========== 标签 ========== */
.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 4rpx 12rpx;
  font-size: 20rpx;
  border-radius: 6rpx;
}
.tag-hot {
  background: #edf4e7;
  color: var(--primary);
}
.tag-new {
  background: #f3eee2;
  color: #9b7b46;
}
.tag-recommend {
  background: #edf4e7;
  color: var(--primary);
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}
.empty-icon {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 24rpx;
  opacity: 0.3;
}
.empty-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 32rpx;
}

/* ========== Flex 布局辅助 ========== */
.flex {
  display: flex;
}
.flex-center {
  display: flex;
  align-items: center;
}
.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.flex-col {
  display: flex;
  flex-direction: column;
}

/* ========== 分割线 ========== */
.divider {
  height: 1rpx;
  background: var(--border);
  margin: 16rpx 0;
}
