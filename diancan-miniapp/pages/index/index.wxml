<view class="page">
  <view class="page-glow page-glow-a"></view>
  <view class="page-glow page-glow-b"></view>
  <view class="hero-shell">
    <view class="hero-orb hero-orb-a"></view>
    <view class="hero-orb hero-orb-b"></view>
    <view class="hero-main" style="padding-top: {{statusBarHeight + navBarHeight + 20}}rpx;">
      <view class="hero-topline">
        <view class="hero-chip">{{table ? '桌台已绑定' : '堂食点餐'}}</view>
        <view class="hero-scene">{{loggedIn ? '已登录' : '未登录'}}</view>
      </view>
      <view class="hero-copy">
        <view class="hero-title">{{heroTitle}}</view>
        <view class="hero-desc">{{heroDesc}}</view>
      </view>
      <view class="hero-footer" wx:if="{{loading || table}}">
        <view class="hero-status">
          <view class="hero-status-label">当前桌台</view>
          <view class="hero-status-value">{{tableStatusText}}</view>
        </view>
      </view>
    </view>
  </view>

  <view class="content-wrap">
    <view class="banner-stage" wx:if="{{banners.length > 0}}">
      <view class="banner-stage-head">
        <view class="section-title">门店活动</view>
        <view class="section-desc">新品、套餐、限时推荐</view>
      </view>
      <swiper
        class="banner-swiper"
        circular
        autoplay
        interval="4200"
        duration="450"
        indicator-dots
        indicator-color="rgba(103, 61, 35, 0.18)"
        indicator-active-color="#07c160"
      >
        <swiper-item wx:for="{{banners}}" wx:key="id">
          <view class="banner-card" bindtap="openBanner" data-banner="{{item}}">
            <image class="banner-image" src="{{item.imageUrl}}" mode="aspectFill"></image>
            <view class="banner-overlay"></view>
            <view class="banner-copy">
              <view class="banner-title">{{item.title}}</view>
              <view class="banner-subtitle" wx:if="{{item.subtitle}}">{{item.subtitle}}</view>
            </view>
          </view>
        </swiper-item>
      </swiper>
    </view>

    <view class="section-card coupon-panel">
      <view class="section-head">
        <view>
          <view class="section-title">今日优惠</view>
          <view class="section-desc">{{loggedIn ? '下单可直接抵扣' : '登录后查看可用优惠券'}}</view>
        </view>
        <view class="section-link" bindtap="goCouponCenter">{{loggedIn ? '全部优惠券' : '去登录'}}</view>
      </view>

      <view class="coupon-list" wx:if="{{loggedIn && coupons.length > 0}}">
        <view class="coupon-card" wx:for="{{coupons}}" wx:key="id">
          <view class="coupon-main">
            <view class="coupon-name">{{item.couponName}}</view>
            <view class="coupon-rule">{{item.displayRule}}</view>
            <view class="coupon-time">有效期至 {{item.validTo}}</view>
          </view>
          <view class="coupon-side">
            <view class="coupon-value">{{item.displayValue}}</view>
            <view class="coupon-badge">可用</view>
          </view>
        </view>
      </view>

      <view class="coupon-empty" wx:else>
        <view class="coupon-empty-title">{{loggedIn ? '暂时没有可用优惠券' : '登录后查看你的专属优惠'}}</view>
        <view class="coupon-empty-desc">{{loggedIn ? '下次活动发券后会显示在这里' : '领券、下单、看订单都更方便'}}</view>
      </view>
    </view>
  </view>

  <view class="mask" wx:if="{{showLoginPanel}}" bindtap="toggleLoginPanel">
    <view class="login-popup" catchtap="noop">
      <view class="login-popup-title">手机号登录</view>
      <view class="login-popup-desc">登录后可领券、下单、查看订单</view>
      <view class="agreement-row" bindtap="toggleAgreeProtocol">
        <view class="agreement-check {{agreeProtocol ? 'checked' : ''}}">
          <text wx:if="{{agreeProtocol}}">✓</text>
        </view>
        <view class="agreement-text">
          已阅读并同意
          <text class="agreement-link" catchtap="openUserAgreement">《用户协议》</text>
          和
          <text class="agreement-link" catchtap="openPrivacyPolicy">《隐私政策》</text>
        </view>
      </view>
      <button
        class="btn-primary login-popup-btn {{!agreeProtocol ? 'login-popup-btn--disabled' : ''}}"
        open-type="{{agreeProtocol ? 'getPhoneNumber' : ''}}"
        bindtap="handlePhoneLoginTap"
        bindgetphonenumber="handlePhoneLogin"
      >
        手机号快捷登录
      </button>
      <view class="login-popup-cancel" bindtap="toggleLoginPanel">暂不登录</view>
    </view>
  </view>
</view>
