<view class="menu-page">
  <view class="page-glow page-glow-a"></view>
  <view class="page-glow page-glow-b"></view>
  <view class="top-card">
    <view class="store-visual" style="padding-top: {{statusBarHeight + 8}}px; min-height: {{statusBarHeight + navBarHeight + 92}}px;">
      <image wx:if="{{menuHeroBanners.length > 0}}" class="store-visual__image" src="{{menuHeroBanners[0].imageUrl}}" mode="aspectFill" />
      <view class="store-visual__wash"></view>
      <view class="store-visual__content">
        <view class="store-visual__eyebrow">堂食点单 · 现点现做</view>
        <view class="store-visual__title">{{menuHeroTitle}}</view>
        <view class="store-visual__meta">
          <view class="store-visual__status-dot"></view>
          <text>{{heroStatusText}}</text>
          <text class="store-visual__divider">·</text>
          <text>{{table ? '桌台 ' + tableDisplayCode : '请先关联桌台'}}</text>
        </view>
      </view>
    </view>

    <view class="menu-hero">
      <view class="hero-banner-stage" wx:if="{{banners.length > 0}}">
        <swiper
          class="hero-banner-swiper"
          circular
          autoplay
          interval="4200"
          duration="450"
          indicator-dots
          indicator-color="rgba(255, 245, 240, 0.24)"
          indicator-active-color="#fff7f2"
        >
          <swiper-item wx:for="{{banners}}" wx:key="id">
            <view class="hero-banner-card" bindtap="openBanner" data-banner="{{item}}">
              <image class="hero-banner-image" src="{{item.imageUrl}}" mode="aspectFill" lazy-load />
              <view class="hero-banner-overlay"></view>
              <view class="hero-banner-copy">
                <view class="hero-banner-title">{{item.title}}</view>
                <view class="hero-banner-subtitle" wx:if="{{item.subtitle}}">{{item.subtitle}}</view>
              </view>
            </view>
          </swiper-item>
        </swiper>
      </view>

      <view class="filter-card compact">
        <view class="search-shell">
          <view class="search-icon">⌕</view>
          <input class="search-input" placeholder="搜索菜品、口味、配料" value="{{keyword}}" bindinput="onKeywordInput" />
        </view>
        <view class="quick-filter-row">
          <view class="quick-filter {{quickFilter === 'all' ? 'active' : ''}}" data-filter="all" bindtap="selectQuickFilter">全部</view>
          <view class="quick-filter {{quickFilter === 'recommend' ? 'active' : ''}}" data-filter="recommend" bindtap="selectQuickFilter">推荐</view>
          <view class="quick-filter {{quickFilter === 'ordered' ? 'active' : ''}}" data-filter="ordered" bindtap="selectQuickFilter">点过</view>
        </view>
      </view>

      <view class="table-entry-notice" wx:if="{{!table}}">
        <view class="table-entry-copy">
          <view class="table-entry-title">还没有关联桌台</view>
          <view class="table-entry-sub">扫码或输入桌台编码后，才能加入购物车和支付。</view>
        </view>
        <button class="table-entry-btn" bindtap="goTableEntry">关联桌台</button>
      </view>
    </view>
  </view>

  <view class="layout">
    <scroll-view class="left-side" scroll-y scroll-with-animation scroll-into-view="{{categoryScrollIntoView}}" show-scrollbar="{{false}}">
      <view
        wx:for="{{categories}}"
        wx:key="id"
        id="category-{{item._idStr}}"
        class="cat-item {{activeCategoryId === item._idStr ? 'active' : ''}}"
        data-id="{{item.id}}"
        bindtap="selectCategory"
      >
        <view class="cat-item__icon-wrap">
          <view class="cat-item__icon">
            <image wx:if="{{item.imageView}}" class="cat-item__image" src="{{item.imageView}}" mode="aspectFill" lazy-load />
            <text wx:else>{{item.shortLabel}}</text>
          </view>
          <text class="cat-item__badge" wx:if="{{item._cartCount > 0}}">{{item._cartCountText}}</text>
        </view>
        <view class="cat-item__copy">
          <text class="cat-item__label">{{item.name}}</text>
        </view>
        <text class="cat-item__active-dot" wx:if="{{activeCategoryId === item._idStr}}"></text>
      </view>
      <view class="cat-scroll-tail">
        <view class="cat-scroll-tail__line"></view>
        <view class="cat-scroll-tail__text">继续下滑查看更多分类</view>
      </view>
    </scroll-view>

    <scroll-view class="right-side" scroll-y show-scrollbar="{{false}}">
      <view class="right-surface">
        <view class="dish-card" wx:for="{{dishList}}" wx:key="id" bindtap="openDetail" data-id="{{item.id}}">
          <view class="dish-card__media">
            <image class="thumb" src="{{item.imageView}}" mode="aspectFill" lazy-load />
            <text class="dish-card__badge" wx:if="{{item._recommended}}">推荐</text>
          </view>
          <view class="info">
            <view class="dish-meta-row">
              <text class="meta-pill spice" wx:if="{{item.spiceLabel}}">{{item.spiceLabel}}</text>
              <text class="meta-pill" wx:if="{{item.preparationTime}}">{{item.preparationTime}} 分钟</text>
            </view>

            <view class="dish-topline">
              <view class="dish-name">{{item.name}}</view>
            </view>

            <view class="dish-sub">{{item.briefText}}</view>

            <view class="dish-bottom">
              <view class="dish-bottom__main">
                <view class="dish-tags">
                  <text class="mini-tag had" wx:if="{{item._ordered}}">点过</text>
                  <text class="soldout-tag" wx:if="{{item.soldOutFlag}}">售罄</text>
                  <text class="dish-sales">月售{{item.monthlySales || 0}}</text>
                </view>
                <view class="dish-price-row">
                  <view class="dish-price">¥{{item.price}}</view>
                  <text class="dish-unit">/份起</text>
                </view>
              </view>
              <button
                class="spec-btn {{item.soldOutFlag ? 'disabled' : ''}}"
                disabled="{{item.soldOutFlag}}"
                data-id="{{item.id}}"
                catchtap="openDetail"
              >
                <text class="spec-btn__text">{{item.soldOutFlag ? '售罄' : '选规格'}}</text>
                <text class="spec-btn__badge" wx:if="{{item._cartCount > 0}}">{{item._cartCountText}}</text>
              </button>
            </view>
          </view>
        </view>

        <empty-state wx:if="{{visibleDishCount === 0}}" text="没有找到匹配的菜品，换个关键词试试" icon="/assets/tabbar/menu.png" />
      </view>
    </scroll-view>
  </view>

  <view class="cart-feedback {{cartFeedbackVisible ? 'show' : ''}}" wx:if="{{cartFeedbackVisible}}">
    {{cartFeedbackText}}
  </view>

  <view class="cart-bar" wx:if="{{table}}">
    <view class="bar-info" bindtap="toggleCartSheet">
      <view class="bar-icon">
        <view class="bar-icon__handle"></view>
        <view class="bar-icon__bag"></view>
        <text class="bar-icon__badge" wx:if="{{cartSummary.totalCount > 0}}">{{cartSummary.totalCountText}}</text>
      </view>
      <view class="bar-copy">
        <view class="bar-sub">已点 {{cartSummary.totalCount}} 份菜品</view>
        <view class="bar-price">¥{{cartSummary.totalPrice}}</view>
      </view>
    </view>
    <view class="bar-btn-wrap">
      <button class="bar-btn" bindtap="goCart">去结算</button>
    </view>
  </view>

  <view class="cart-sheet-mask {{cartSheetVisible ? 'show' : ''}}" wx:if="{{cartSheetVisible}}" bindtap="closeCartSheet"></view>
  <view class="cart-sheet {{cartSheetVisible ? 'show' : ''}}" wx:if="{{cartSheetVisible}}">
    <view class="cart-sheet__head">
      <view class="cart-sheet__select">
        <view class="cart-sheet__check">✓</view>
        <text>已选菜品</text>
        <text class="cart-sheet__count">{{cartSummary.totalCount}} 份</text>
      </view>
      <view class="cart-sheet__clear" bindtap="clearMenuCart">
        <view class="trash-icon"></view>
        <text>清空</text>
      </view>
    </view>
    <scroll-view class="cart-sheet__list" scroll-y show-scrollbar="{{false}}">
      <view class="cart-sheet__item" wx:for="{{cartItems}}" wx:key="dishId">
        <view class="cart-sheet__check cart-sheet__check--small">✓</view>
        <image class="cart-sheet__image" src="{{item.imageView}}" mode="aspectFill" />
        <view class="cart-sheet__info">
          <view class="cart-sheet__name">{{item.dishName}}</view>
          <view class="cart-sheet__remark" wx:if="{{item.remark}}">{{item.remark}}</view>
          <view class="cart-sheet__price">¥{{item.priceText}}</view>
        </view>
        <view class="cart-sheet__stepper">
          <view class="cart-sheet__step {{cartUpdatingDishId ? 'disabled' : ''}}" data-item="{{item}}" data-delta="-1" bindtap="changeCartQuantity">−</view>
          <text class="cart-sheet__quantity">{{item.quantity}}</text>
          <view class="cart-sheet__step cart-sheet__step--plus {{cartUpdatingDishId ? 'disabled' : ''}}" data-item="{{item}}" data-delta="1" bindtap="changeCartQuantity">＋</view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="mask sheet-mask" wx:if="{{detailVisible}}" bindtap="closeDetail">
    <view class="popup sheet-popup" catchtap="noop">
      <view class="popup-handle"></view>
      <view class="popup-scroll">
        <view class="popup-hero">
          <image class="popup-img" src="{{detailDish.imageView}}" mode="aspectFill" />
          <view class="popup-copy">
            <view class="popup-tag-row">
              <text class="popup-tag">{{detailDish.categoryName}}</text>
              <text class="popup-tag spice">{{detailDish.spiceLabel}}</text>
              <text class="popup-tag" wx:if="{{detailDish.preparationTime}}">{{detailDish.preparationTime}} 分钟</text>
            </view>
            <view class="popup-title">{{detailDish.name}}</view>
            <view class="popup-price">¥{{detailDish.price}}</view>
            <view class="popup-meta" wx:if="{{detailDish.description}}">{{detailDish.description}}</view>
          </view>
        </view>

        <view class="popup-section" wx:if="{{detailHasIngredients}}">
          <view class="section-head">
            <view class="section-title">配料参考</view>
            <view class="section-sub">下单前先看主要食材，避免重复确认。</view>
          </view>
          <view class="ingredient-row">
            <text class="ingredient-chip" wx:for="{{detailDish.ingredientsList}}" wx:key="index">{{item}}</text>
          </view>
        </view>

        <view class="popup-section">
          <view class="section-head">
            <view class="section-title">选数量</view>
            <view class="section-sub">确认份数后加入购物车，购物车里再统一下单。</view>
          </view>
          <view class="qty-panel">
            <view class="qty-btn qty-btn-minus" bindtap="decreaseDetailQty">
              <text class="qty-icon">−</text>
            </view>
            <view class="qty-num">{{detailQty}}</view>
            <view class="qty-btn qty-btn-plus" bindtap="increaseDetailQty">
              <text class="qty-icon">＋</text>
            </view>
          </view>
        </view>

        <view class="popup-section">
          <view class="section-head">
            <view class="section-title">口味要求</view>
            <view class="section-sub">例如少辣、不要香菜、先上热菜。</view>
          </view>
          <textarea
            class="remark-input"
            maxlength="120"
            auto-height
            placeholder="请输入你的备注"
            value="{{detailRemark}}"
            bindinput="onDetailRemarkInput"
          />
        </view>
      </view>

      <view class="popup-actions">
        <button class="act-add" bindtap="confirmDetailAdd">加入购物车</button>
      </view>
    </view>
  </view>

  <view class="mask" wx:if="{{showLoginPanel}}" bindtap="closeLoginPanel">
    <view class="login-popup" catchtap="noop">
      <view class="login-popup-icon">登录</view>
      <view class="login-popup-title">手机号登录</view>
      <view class="login-popup-desc">登录后可下单、加入购物车</view>
      <view class="agreement-row" bindtap="toggleAgreeProtocol">
        <view class="agreement-check {{agreeProtocol ? 'checked' : ''}}">
          <text wx:if="{{agreeProtocol}}">✓</text>
        </view>
        <view class="agreement-text">
          已阅读并同意
          <text class="agreement-link" catchtap="openUserAgreement">《用户协议》</text>
          和
          <text class="agreement-link" catchtap="openPrivacyPolicy">《隐私政策》</text>
        </view>
      </view>
      <button
        class="btn-primary login-popup-btn {{!agreeProtocol ? 'login-popup-btn--disabled' : ''}}"
        open-type="{{agreeProtocol ? 'getPhoneNumber' : ''}}"
        bindtap="handlePhoneLoginTap"
        bindgetphonenumber="handlePhoneLogin"
      >
        手机号快捷登录
      </button>
      <view class="login-popup-cancel" bindtap="closeLoginPanel">暂不登录</view>
    </view>
  </view>
</view>
